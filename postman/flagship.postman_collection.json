                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key_b}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tenants/{{tenant_id}}/flags",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tenants", "{{tenant_id}}", "flags"]
            }
          }
