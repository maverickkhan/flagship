      "name": "4 · Audit & lifecycle",
      "item": [
        {
          "name": "History — chronological with old/new values",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('created + updated entries with pre-images', () => {",
                  "  const h = pm.response.json().history;",
                  "  const actions = h.map(e => e.action);",
                  "  pm.expect(actions).to.include('flag.created');",
                  "  pm.expect(actions).to.include('flag.updated');",
                  "  const upd = h.find(e => e.action === 'flag.updated' && e.environment === 'production');",
                  "  pm.expect(upd.old_value).to.exist;",
                  "  pm.expect(upd.new_value).to.exist;",
                  "  pm.expect(upd.request_id).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tenants/{{tenant_id}}/flags/checkout-v2/history",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tenants", "{{tenant_id}}", "flags", "checkout-v2", "history"]
            }
          }
        },
