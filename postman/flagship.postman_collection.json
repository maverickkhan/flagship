    {
      "name": "5 · Security & isolation",
      "item": [
        {
          "name": "No API key → 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 Unauthenticated', () => pm.response.to.have.status(401));",
                  "pm.test('envelope + request_id', () => {",
                  "  const b = pm.response.json();",
                  "  pm.expect(b.error.code).to.eql('UNAUTHENTICATED');",
                  "  pm.expect(b.request_id).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tenants/{{tenant_id}}/flags",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tenants", "{{tenant_id}}", "flags"]
            }
