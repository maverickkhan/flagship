# Local development environment. Copy to .env for host-based runs;
# docker-compose sets these itself. In GCP all secrets come from Secret Manager.
NODE_ENV=development
PORT=8080
# Host ports 5434/6380 avoid clashing with locally installed Postgres/Redis.
DATABASE_URL=postgresql://flagship:flagship@localhost:5434/flagship?schema=public
REDIS_URL=redis://localhost:6380
# Bootstrap secret guarding POST /api/v1/tenants (Secret Manager in cloud).
ADMIN_TOKEN=local-dev-admin-token
LOG_LEVEL=debug
LOG_PRETTY=true
RATE_LIMIT_EVALUATE_PER_MIN=600
RATE_LIMIT_MANAGEMENT_PER_MIN=120
RATE_LIMIT_IP_PER_MIN=60
# Comma-separated tenant IDs exempt from tenant rate limits (load testing).
RATE_LIMIT_EXEMPT_TENANTS=
